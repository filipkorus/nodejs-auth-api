{
  "compilerOptions": {
    "target": "es2016",
    "outDir": "./dist/",
    "rootDir": "./src/",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  }
}